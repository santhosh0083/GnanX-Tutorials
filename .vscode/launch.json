{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run GnanX Server",
      "program": "${workspaceFolder}/server.js",
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "8080"
      },
      "console": "integratedTerminal",
      "restart": true,
      "serverReadyAction": {
        "pattern": "Server running on (http://localhost:[0-9]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open GnanX Website",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/public"
    }
  ]
}
